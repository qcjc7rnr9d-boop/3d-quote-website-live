# ── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_CLIENT_ID=ca_xxxx
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Shopify custom app ─────────────────────────────────────
# Create/link the app in Shopify Partner Dashboard, then mirror these values
# into shopify.app.toml before running Shopify CLI deploy commands.
SHOPIFY_API_KEY=...
SHOPIFY_API_SECRET=shpss_...
SHOPIFY_APP_URL=https://yourdomain.com
SHOPIFY_SCOPES=write_draft_orders,read_draft_orders,read_orders,write_app_proxy
SHOPIFY_API_VERSION=2026-04
# Dev only: lets you open /apps/3d-quote without Shopify proxy signatures.
SHOPIFY_ALLOW_UNSIGNED_PROXY=0
# Test/dev only: returns draft order payloads without calling Shopify.
SHOPIFY_DRAFT_ORDER_DRY_RUN=0

# ── Shopify quote file storage ─────────────────────────────
# Local disk is allowed only outside production. Production should use S3 or
# an S3-compatible service such as Cloudflare R2, Backblaze B2, or AWS S3.
SHOPIFY_FILE_STORAGE=s3
SHOPIFY_S3_BUCKET=...
SHOPIFY_S3_REGION=auto
SHOPIFY_S3_ENDPOINT=https://...
SHOPIFY_S3_ACCESS_KEY_ID=...
SHOPIFY_S3_SECRET_ACCESS_KEY=...
SHOPIFY_S3_FORCE_PATH_STYLE=1
SHOPIFY_S3_PUBLIC_BASE_URL=
SHOPIFY_S3_SIGNED_URL_SECONDS=604800

# ── Auth / Sessions ────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_string_min_32_chars
SESSION_SECRET=replace_with_another_long_random_string
# Required in production. Used to encrypt platform-managed Stripe secrets
# before they are written to SQLite.
PLATFORM_CONFIG_ENCRYPTION_KEY=replace_with_a_long_random_string_min_32_chars

# ── App ───────────────────────────────────────────────────
BASE_URL=https://yourdomain.com
PORT=3001
NODE_ENV=production

# ── Email ──────────────────────────────────────────────────
# The mailer picks a provider in this order:
#   1. Resend HTTP API   — set RESEND_API_KEY  (recommended)
#   2. SMTP via nodemailer — set SMTP_HOST     (Google Workspace / M365 / generic SMTP)
#   3. Ethereal preview  — no config (dev only, NO real delivery)
# In every case, EMAIL_FROM controls the visible "From" address.

# ── Option A: Resend (recommended) ─────────────────────────
# 1. Sign up at https://resend.com (free tier: 3000 emails/mo)
# 2. Add your domain (e.g. yourdomain.com) under "Domains"
# 3. Add the DKIM + SPF DNS records Resend shows you (~5 minutes to verify)
# 4. Create an API key under "API Keys" and paste below
# 5. Set EMAIL_FROM to a name+address on your verified domain
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Mahi3d <hello@yourdomain.com>

# ── Option B: SMTP fallback (uncomment + fill in if not using Resend) ─
# Works with Google Workspace (smtp.gmail.com, port 587, app password),
# Microsoft 365 (smtp.office365.com), Brevo, Postmark SMTP, etc.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false           # true for port 465 (TLS-on-connect)
# SMTP_USER=hello@yourdomain.com
# SMTP_PASS=your_smtp_or_app_password
# EMAIL_FROM=Mahi3d <hello@yourdomain.com>

# ── Platform Admin ─────────────────────────────────────────
PLATFORM_ADMIN_PASSWORD=set_a_strong_password_here
