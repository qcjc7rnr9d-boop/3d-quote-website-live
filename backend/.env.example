# ── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_CLIENT_ID=ca_xxxx
STRIPE_WEBHOOK_SECRET=whsec_...

# Business memberships are free in v1. Businesses still need Stripe Connect
# onboarding before they can accept customer payments.

# ── Auth / Sessions ────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_string_min_32_chars
SESSION_SECRET=replace_with_another_long_random_string
# Required in production. Used to encrypt platform-managed Stripe secrets
# before they are written to SQLite.
PLATFORM_CONFIG_ENCRYPTION_KEY=replace_with_a_long_random_string_min_32_chars

# ── App ───────────────────────────────────────────────────
# Replace this with the hosted app URL once your domain/HTTPS is live.
BASE_URL=https://app.trennen.co.nz
PORT=3001
NODE_ENV=production

# ── Email ──────────────────────────────────────────────────
# The mailer picks a provider in this order:
#   1. Resend HTTP API   — set RESEND_API_KEY  (recommended)
#   2. SMTP via nodemailer — set SMTP_HOST     (Google Workspace / M365 / generic SMTP)
#   3. Ethereal preview  — no config (dev only, NO real delivery)
# Platform fallback email should use a verified sending subdomain, not the
# bare/root domain. Clients can later verify their own subdomains in shop
# settings, but until then their customer emails send through this domain
# with Reply-To pointing at the business support inbox.

# ── Option A: Resend (recommended) ─────────────────────────
# 1. Add mail.trennen.co.nz under Resend "Domains"
# 2. Add the DNS records Resend shows into the trennen.co.nz DNS zone
# 3. Add DMARC for the sending subdomain, starting safely at p=none
# 4. Create a new restricted/sending-only API key after verification
# 5. Paste real secrets only into backend/.env on the server; never commit them
RESEND_API_KEY=replace-with-new-rotated-restricted-key
EMAIL_FROM=Trennen <hello@mail.trennen.co.nz>
APP_EMAIL_DOMAIN=mail.trennen.co.nz
APP_EMAIL_FALLBACK=Trennen <hello@mail.trennen.co.nz>
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Option B: SMTP fallback (uncomment + fill in if not using Resend) ─
# Works with Google Workspace (smtp.gmail.com, port 587, app password),
# Microsoft 365 (smtp.office365.com), Brevo, Postmark SMTP, etc.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false           # true for port 465 (TLS-on-connect)
# SMTP_USER=hello@mail.trennen.co.nz
# SMTP_PASS=your_smtp_or_app_password
# EMAIL_FROM=Trennen <hello@mail.trennen.co.nz>

# ── Platform Admin ─────────────────────────────────────────
PLATFORM_ADMIN_PASSWORD=set_a_strong_password_here
