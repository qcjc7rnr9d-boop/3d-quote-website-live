# ── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=replace-with-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=replace-with-stripe-publishable-key
STRIPE_CLIENT_ID=replace-with-stripe-connect-client-id
STRIPE_WEBHOOK_SECRET=replace-with-stripe-webhook-secret

# Trennen SaaS subscriptions use Stripe Billing for paid plans.
# Community remains free.
STRIPE_BILLING_STARTER_PRICE_ID=price_...
STRIPE_BILLING_GROWTH_PRICE_ID=price_...
STRIPE_BILLING_SCALE_PRICE_ID=price_...

# Estimated card processing rates are for customer-facing estimates only.
# Actual Stripe fees are stored from balance transaction records after payment.
ESTIMATED_CARD_FEE_BASIS_POINTS=290
ESTIMATED_CARD_FEE_FIXED_CENTS=30

# ── Auth / Sessions ────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_string_min_32_chars
SESSION_SECRET=replace_with_another_long_random_string
# Required in production. Used to encrypt platform-managed Stripe secrets
# before they are written to SQLite.
PLATFORM_CONFIG_ENCRYPTION_KEY=replace_with_a_long_random_string_min_32_chars

# ── App ───────────────────────────────────────────────────
BASE_URL=https://app.trennen.co.nz
PORT=3001
NODE_ENV=production
# Required behind Nginx/Lightsail so rate limiting reads proxy headers safely.
TRUST_PROXY=1

# ── Email ──────────────────────────────────────────────────
# The mailer picks a provider in this order:
#   1. Resend HTTP API   — set RESEND_API_KEY  (recommended)
#   2. SMTP via nodemailer — set SMTP_HOST     (Google Workspace / M365 / generic SMTP)
#   3. Ethereal preview  — no config (dev only, NO real delivery)
# Platform fallback email should use a verified sending subdomain, not the
# bare/root domain. Client-branded sending domains can be added per shop later.

# ── Option A: Resend (recommended) ─────────────────────────
# Verify mail.trennen.co.nz in Resend first, then paste real secrets only into
# the live server's backend/.env. Do not commit real API keys.
RESEND_API_KEY=replace-with-new-rotated-restricted-key
EMAIL_FROM=Trennen <hello@mail.trennen.co.nz>
APP_EMAIL_DOMAIN=mail.trennen.co.nz
APP_EMAIL_FALLBACK=Trennen <hello@mail.trennen.co.nz>
RESEND_WEBHOOK_SECRET=replace-with-resend-webhook-secret

# ── Option B: SMTP fallback (uncomment + fill in if not using Resend) ─
# Works with Google Workspace (smtp.gmail.com, port 587, app password),
# Microsoft 365 (smtp.office365.com), Brevo, Postmark SMTP, etc.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false           # true for port 465 (TLS-on-connect)
# SMTP_USER=hello@mail.trennen.co.nz
# SMTP_PASS=your_smtp_or_app_password
# EMAIL_FROM=Trennen <hello@mail.trennen.co.nz>

# ── Future Managed AWS Migration ───────────────────────────
# Current Lightsail demo uses local SQLite and local uploads. These names are
# reserved for the later App Runner + RDS PostgreSQL + S3 migration.
DATABASE_URL=
STORAGE_DRIVER=local
S3_UPLOADS_BUCKET=
AWS_REGION=ap-southeast-2
SECRETS_MANAGER_PREFIX=

# ── Platform Admin ─────────────────────────────────────────
PLATFORM_ADMIN_PASSWORD=set_a_strong_password_here
