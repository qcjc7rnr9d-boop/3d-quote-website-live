# Copy to /opt/trennen/3d-quote-website/backend/.env on the Lightsail server.
# Replace every placeholder before starting the service. Never commit real values.

NODE_ENV=production
PORT=3001
BASE_URL=https://app.trennen.co.nz
TRUST_PROXY=1
PLATFORM_DOMAIN=trennen.co.nz

SESSION_SECRET=replace_with_64_plus_random_chars
JWT_SECRET=replace_with_a_different_64_plus_random_chars
PLATFORM_CONFIG_ENCRYPTION_KEY=replace_with_a_third_64_plus_random_chars
PLATFORM_ADMIN_PASSWORD=replace_with_a_strong_admin_password

APP_EMAIL_DOMAIN=mail.trennen.co.nz
APP_EMAIL_FALLBACK="Trennen <hello@mail.trennen.co.nz>"
EMAIL_FROM="Trennen <hello@mail.trennen.co.nz>"
SALES_DEMO_TO=hello@trennen.co.nz
RESEND_API_KEY=replace_with_resend_api_key
RESEND_WEBHOOK_SECRET=replace_with_resend_webhook_signing_secret

STRIPE_SECRET_KEY=replace_with_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=replace_with_stripe_publishable_key
STRIPE_CLIENT_ID=replace_with_stripe_connect_client_id
STRIPE_WEBHOOK_SECRET=replace_with_stripe_webhook_secret
STRIPE_BILLING_STARTER_PRICE_ID=replace_with_starter_monthly_price_id
STRIPE_BILLING_GROWTH_PRICE_ID=replace_with_growth_monthly_price_id
STRIPE_BILLING_SCALE_PRICE_ID=replace_with_scale_monthly_price_id

SHOPIFY_API_KEY=replace_if_shopify_app_is_enabled
SHOPIFY_API_SECRET=replace_if_shopify_app_is_enabled
SHOPIFY_APP_URL=https://app.trennen.co.nz
SHOPIFY_SCOPES=write_draft_orders,read_draft_orders,read_orders,write_app_proxy
SHOPIFY_API_VERSION=2026-04
SHOPIFY_ALLOW_UNSIGNED_PROXY=0
SHOPIFY_DRAFT_ORDER_DRY_RUN=0

SHOPIFY_FILE_STORAGE=s3
SHOPIFY_S3_BUCKET=replace_with_bucket_name
SHOPIFY_S3_REGION=auto
SHOPIFY_S3_ENDPOINT=replace_with_s3_or_r2_endpoint
SHOPIFY_S3_ACCESS_KEY_ID=replace_with_s3_access_key
SHOPIFY_S3_SECRET_ACCESS_KEY=replace_with_s3_secret_key
SHOPIFY_S3_FORCE_PATH_STYLE=1
SHOPIFY_S3_PUBLIC_BASE_URL=
SHOPIFY_S3_SIGNED_URL_SECONDS=604800
